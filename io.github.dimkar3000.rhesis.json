{
	"id": "io.github.dimkar3000.rhesis",
	"runtime": "org.kde.Platform",
	"runtime-version": "6.11",
	"sdk": "org.kde.Sdk",
	"command": "rhesis",
	"desktop-file-name-suffix": "",
	"finish-args": [
		"--share=ipc",
		"--share=network",
		"--device=dri",
		"--socket=fallback-x11",
		"--socket=wayland"
	],
	"modules": [
		{
			"name": "rhesis",
			"buildsystem": "simple",
			"build-commands": [
				"install -Dm755 rhesis /app/bin/rhesis",
				"cp -r LanguageTool /app/",
				"cp lid.176.ftz /app/",
				"cp -r translations /app/bin/",
				"mkdir -p /app/share && cp -r share/* /app/share/",
				"install -Dm755 fasttext-source/fasttext /app/fasttext",
				"cp -r java-source/jre /app/",
				"ln -s /app/jre/bin/java /app/bin/java"
			],
			"sources": [
				{
					"type": "dir",
					"path": "build/artifacts/app"
				},
				{
					"type": "dir",
					"path": "build/artifacts/fastText",
					"dest": "fasttext-source"
				},
				{
					"type": "dir",
					"path": "build/artifacts/java",
					"dest": "java-source"
				}
			]
		}
	]
}
